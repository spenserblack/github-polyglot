root = true

[*]
end_of_line = LF
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# CSS
[*.css]
indent_style = space
indent_size = 2

# Docker
[Dockerfile]
indent_style = space
indent_size = 4

# JSON
[*.json]
indent_style = space
indent_size = 2

# Ruby
[*.rb]
indent_style = space
indent_size = 2
[.gemspec]
indent_style = space
indent_size = 2
[Gemfile]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2
